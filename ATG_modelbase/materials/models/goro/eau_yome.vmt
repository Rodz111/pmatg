"UnlitGeneric"
{
    "$basetexture" "models/loeve/m_yome_katana/m_yome_katana"
    "$additive" "1"
    "$translucent" "1"
    "$alpha" "0.35"
    "$color" "[0.3 0.6 1.0]"
    "$nocull" "1"

    "Proxies"
    {
        "TextureScroll"
        {
            "texturescrollvar" "$basetexturetransform"
            "texturescrollrate" 0.13
            "texturescrollangle" 5
        }

        "Sine"
        {
            "resultVar" "$alpha"
            "sinemin" "0.25"
            "sinemax" "0.45"
            "sineperiod" "15"
        }
    }
}