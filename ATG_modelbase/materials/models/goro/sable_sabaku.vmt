"UnlitGeneric"
{
	"$basetexture" "models/goro/sable_sabaku"
    "$additive" "1"
    "$translucent" "1"
    "$vertexalpha" "1"
    "$vertexcolor" "1"
    "$nocull" "1"

    "$selfillum" "1"
    "$selfillumtint" "[1 0.8 0.5]"

    "$envmap" "env_cubemap"
    "$envmaptint" "[0.3 0.25 0.1]"

    "Proxies"
    {
        "TextureScroll"
        {
            "texturescrollvar" "$basetexturetransform"
            "texturescrollrate" 0.02
            "texturescrollangle" 35
        }

        "Sine"
        {
            "resultVar" "$alpha"
            "sinemin" "0.15"
            "sinemax" "0.4"
            "sineperiod" "4"
        }

        "Sine"
        {
            "resultVar" "$color"
            "sinemin" "[0.9 0.75 0.5]"
            "sinemax" "[1.0 0.85 0.6]"
            "sineperiod" "6"
        }
    }
}