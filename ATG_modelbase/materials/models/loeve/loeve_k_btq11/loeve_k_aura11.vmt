"UnlitGeneric"
{
    "$basetexture" "models/loeve/loeve_k_btq11/loeve_k_aura11"
    "$additive" "1"
    "$alpha" "0.35"
    "$color" "[0.3 0.6 1.0]"
    "$nocull" "1"

    "Proxies"
    {
        "TextureScroll"
        {
            "texturescrollvar" "$basetexturetransform"
            "texturescrollrate" 0.62
            "texturescrollangle" 90
        }

        "Sine"
        {
            "resultVar" "$alpha"
            "sinemin" "0.25"             
            "sinemax" "0.45"             
            "sineperiod" "15"           
        }
    }
}