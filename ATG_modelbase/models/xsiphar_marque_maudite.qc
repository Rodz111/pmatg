$jigglebone "bande1"
{
	is_flexible
	{
		length 24
		tip_mass 3
		pitch_stiffness 60
		pitch_damping 6
		yaw_stiffness 60
		yaw_damping 6
		allow_length_flex
		along_stiffness 90
		along_damping 2
		pitch_constraint -10 19.999999
		pitch_friction 0
		pitch_bounce 0
		angle_constraint 25
	}
}
